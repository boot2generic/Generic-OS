# Whitelist .gitignore: track ONLY the build source; ignore everything
# live-build generates (chroot/, binary/, cache/, .build/, local/, .lock,
# chroot.*, build.log, ISOs, and the config/ subtrees `lb config` regenerates
# incl. its own hook symlinks). Pattern: ignore all, then re-include our inputs.

/*

# --- top-level source we maintain ---
!/.gitignore
!/README.md
!/config.env
!/build.sh
!/container-build.sh
!/check-packages.sh
!/validate-iso.sh
!/make-kali-key.sh
!/auto/
!/docs/
!/editions/
!/extras/
!/variants/
!/config/

# --- config/ is mostly regenerated by `lb config`; keep only our inputs ---
/config/*
!/config/hooks/
!/config/package-lists/
!/config/includes.chroot/

# hooks/: our hooks only (live-build drops its own symlinks into normal/)
/config/hooks/*
!/config/hooks/normal/
/config/hooks/normal/*
!/config/hooks/normal/0100-multiarch.hook.chroot
!/config/hooks/normal/0150-build-user.hook.chroot
!/config/hooks/normal/0200-deploy-skel.hook.chroot
!/config/hooks/normal/0300-deploy-apps.hook.chroot
!/config/hooks/normal/0400-kali-tools.hook.chroot
!/config/hooks/normal/0450-gaming-extras.hook.chroot
!/config/hooks/normal/0500-terminal-skel.hook.chroot
!/config/hooks/normal/0600-nvidia-bake.hook.chroot
!/config/hooks/normal/0700-enable-services.hook.chroot
!/config/hooks/normal/0900-stop-build-daemons.hook.chroot
!/config/hooks/normal/9999-cleanup.hook.chroot

# package-lists/: our always-on lists only (25/30/40/50/live are staged/generated)
/config/package-lists/*
!/config/package-lists/00-base.list.chroot
!/config/package-lists/10-desktop-plasma.list.chroot
!/config/package-lists/20-gpu-universal.list.chroot

# includes.chroot/: only the placeholder; all staged content is generated
/config/includes.chroot/*
!/config/includes.chroot/.gitkeep
