# Whitelist .gitignore: track ONLY the build source; ignore everything else.
# The leading `/*` ignores every path not re-included below, which already
# covers all generated/transient artifacts, namely:
#   build:      chroot/, binary/, cache/, .build/, local/, .lock, chroot.*,
#               build.log, live-image-*.iso, out/*.iso, and the config/ subtrees
#               `lb config` regenerates (incl. its own hook symlinks),
#               config/includes.chroot_before_packages/ (build-only apt/dpkg drop-ins).
#   validation: validate.log, out/boot-validate/ (screenshots *.png, *.report.txt,
#               *.serial.log, boot-validate.log) — all under out/, all ignored.
#   container:  the runtime image lives in podman/docker storage, not the repo.
# Nothing extra is needed to ignore new artifacts here; they fall under `/*`.
# The real maintenance is the OPPOSITE — a NEW SOURCE file must be re-included
# below or the whitelist silently drops it. Add such files to the lists that follow.

/*

# --- top-level source we maintain ---
!/.gitignore
!/README.md
!/config.env
!/build.sh
!/container-build.sh
!/check-packages.sh
!/validate-iso.sh
!/validate-boot.sh
!/validate-boot.py
!/make-kali-key.sh
!/auto/
!/docs/
!/editions/
!/extras/
!/variants/
!/config/

# --- config/ is mostly regenerated by `lb config`; keep only our inputs ---
/config/*
!/config/hooks/
!/config/package-lists/
!/config/includes.chroot/
!/config/bootloaders/

# hooks/: our hooks only (live-build drops its own symlinks into normal/)
/config/hooks/*
!/config/hooks/normal/
/config/hooks/normal/*
!/config/hooks/normal/0100-multiarch.hook.chroot
!/config/hooks/normal/0150-build-user.hook.chroot
!/config/hooks/normal/0200-deploy-skel.hook.chroot
!/config/hooks/normal/0300-deploy-apps.hook.chroot
!/config/hooks/normal/0400-kali-tools.hook.chroot
!/config/hooks/normal/0450-gaming-extras.hook.chroot
!/config/hooks/normal/0500-terminal-skel.hook.chroot
!/config/hooks/normal/0600-nvidia-bake.hook.chroot
!/config/hooks/normal/0800-live-autologin.hook.chroot
!/config/hooks/normal/0850-branding.hook.chroot
!/config/hooks/normal/0700-enable-services.hook.chroot
!/config/hooks/normal/0900-stop-build-daemons.hook.chroot
!/config/hooks/normal/9999-cleanup.hook.chroot

# package-lists/: our always-on lists only (25/30/40/50/live are staged/generated)
/config/package-lists/*
!/config/package-lists/00-base.list.chroot
!/config/package-lists/10-desktop-plasma.list.chroot
!/config/package-lists/20-gpu-universal.list.chroot

# includes.chroot/: only the placeholder; all staged content is generated
/config/includes.chroot/*
!/config/includes.chroot/.gitkeep
