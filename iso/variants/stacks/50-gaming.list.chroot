# Full gaming stack. Requires contrib/non-free. steam-installer is NOT here:
# it hard-depends on steam-libs-i386, and i386 isn't enabled until the 0100
# hook (which runs after list install), so the 0100 hook installs steam.
gamemode
mangohud
wine
winetricks
lutris
vkbasalt
pipx
yad
# Native, baked by the 0450-gaming-extras hook (no flatpak):
#   gamescope    → official trixie-backports repo (BACKPORTS=1)
#   protontricks → pipx (real upstream CLI; not in Debian trixie)
