# Build parameters — the single source of truth. Edit here.
# Move to Debian 14: change DEBIAN_SUITE, then `./build.sh clean`.

DEBIAN_SUITE=trixie                              # Debian codename (13=trixie)
DEBIAN_MIRROR=https://deb.debian.org/debian
ARCH=amd64

# Editions to build. Each is defined declaratively in editions/<name>.env
# (which stacks, app tiers, Kali settings, and GPU variants it produces).
EDITIONS="everything security gaming"

ARCHIVE_AREAS="main contrib non-free non-free-firmware"
ISO_VOLUME_PREFIX=generic-os

# Kali archive signing key (pinned, hard-fail on mismatch — same discipline as
# the Mullvad/LibreWolf installers). Verify/update per:
#   https://www.kali.org/blog/new-kali-archive-signing-key/
KALI_KEYRING_URL=https://archive.kali.org/archive-keyring.gpg
KALI_KEY_FPR=827C8569F2518CC677FECA1AED65462EC8D5E4C5
