# Security edition: dev + security tooling, all app tiers.
# Kali repo (pinned-low) + a curated set of common Kali tools baked in.
STACKS="dev security"
KALI_REPO=1
KALI_TOOLS=1            # bake extras/kali/kali-tools.list
BACKPORTS=0            # no backports packages needed for this edition
APPS_TIERS=""           # empty = all tiers
VARIANTS="universal"
