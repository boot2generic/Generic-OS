# Everything edition: dev + security + gaming, all app tiers.
# Kali repo present (pinned-low) for on-demand installs, but NO Kali tools
# pre-baked — fewer security tools than the security edition.
STACKS="dev security gaming"
KALI_REPO=1
KALI_TOOLS=0
APPS_TIERS=""            # empty = all tiers
VARIANTS="universal nvidia"
